  m_Script: {fileID: 11500000, guid: 16624724c53223d4f95cc1697e4a5257, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CassetteDeck
  speakerName: '[ Guard Log: Krit ]'
  lines:
  - "Guard Krit's log \u2014 March 14, 2387, 02:47."
  - Unknown life form breached through the ventilation ducts. Multiple crew members
    vanished overnight.
  - I sent an SOS to Station Helios-7. No response yet.
  - "If anyone reads this \u2014 get to Docking Bay C. The emergency shuttle is still
    operational."
  - Don't waste time. It's still in the station.
  lockPlayerWhileReading: 1
  typewriterSpeed: 38
